<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.pichlermathias.marchvalidation</id>
    <name>march-validation</name>
    <vendor>pichlermathias</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>com.intellij.modules.xml</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="marchvalidation.toolWindow.MyToolWindowFactory" id="MyToolWindow"/>
        <postStartupActivity implementation="marchvalidation.startup.MyProjectActivity" />
        <standardResource
                path="march-config.xsd"
                url="/schemas/march-config.xsd"/>
        <dom.fileMetaData
                implementation="marchvalidation.dom.MarchFileDescription"
                rootTagName="march"
                stubVersion="2"/>
        <annotator
                language="XML"
                implementationClass="marchvalidation.dom.annotators.DimensionsAnnotator"/>
        <annotator
                language="XML"
                implementationClass="marchvalidation.dom.annotators.PartitionsAnnotator"/>
        <annotator
                language="XML"
                implementationClass="marchvalidation.dom.annotators.PartitionMatchAnnotator"/>
        <annotator
                language="XML"
                implementationClass="marchvalidation.dom.annotators.DimensionAncestryAnnotator"/>

        <!--<annotator
                language="XML"
                implementationClass="marchvalidation.dom.annotators.ArchRuleAnnotator"/>-->
        <annotator
                language="ArchRule"
                implementationClass="marchvalidation.dom.annotators.MarchRuleDefinitionAnnotator"/>

        <fileType name="ArchRule"
                  implementationClass="marchvalidation.rules.MarchRuleDefinitionFileType"
                  fieldName="INSTANCE"
                  language="ArchRule"
                  extensions="arch"/>
        <lang.parserDefinition language="ArchRule"
                               implementationClass="marchvalidation.rules.RuleParserDefinition"/>

        <multiHostInjector implementation="marchvalidation.injection.MarchRuleDefinitionInjector"/>

        <psi.referenceContributor language="ArchRule"
                                  implementation="marchvalidation.dom.contributors.MrchRuleDefinitionReferenceContributor"/>

    </extensions>
</idea-plugin>
